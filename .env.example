# Copy to .env and fill in the keys for whichever providers llm_config.yaml uses.
# The default config runs every node on Ollama Cloud, so OLLAMA_API_KEY alone
# is enough out of the box.

# Ollama Cloud (https://ollama.com/settings/keys) — default workhorse provider.
OLLAMA_API_KEY=

# Optional: only needed if you point a node at one of these premium providers.
GOOGLE_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: override the local Ollama daemon location (provider: "ollama").
# OLLAMA_BASE_URL=http://localhost:11434
